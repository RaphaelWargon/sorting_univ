mutate(
treat_opponent  = ifelse(unique_author_id %in% df_treat_opponent$unique_author_id,  1, 0),
treat_ally      = ifelse(unique_author_id %in% df_treat_ally$unique_author_id,      1, 0),
control_opponent = ifelse(unique_author_id %in% df_control_opponents$unique_author_id, 1, 0),
control_ally     = ifelse(unique_author_id %in% df_control_ally$unique_author_id,     1, 0)
)
# Sanity check — overlap across groups
df_reg |>
select(unique_author_id, treat_opponent, treat_ally, control_opponent, control_ally) |>
distinct() |>
group_by(treat_ally, control_ally) |>
count()
