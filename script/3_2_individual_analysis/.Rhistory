df_cris_pol_index <- fread(sprintf(
"D:/openalex-snapshot/merge/final_balanced_panel_authors_%s_%s.csv",
start_year, end_year
))[
pub_year >= 2000 & au_domain_oa != "" & data_source_name == "mtmt"
] %>%
select(unique_author_id, author_national_base_id,
contains("is."), contains("C_")) %>%
mutate(author_national_base_id = as.character(author_national_base_id)) %>%
distinct() %>%
filter(!is.na(C_CEU_2000_2010_network))
df <- merge(df,
df_cris_pol_index,
by = "author_national_base_id",
all.x = TRUE)
} else {
