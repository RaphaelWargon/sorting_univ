# --- Panel + join the political index ---
df <- open_dataset("C:/Users/luc.paluskiewicz/Desktop/panel_hun/full_panel_w_political.parquet/") %>%
filter(assigned_country == "HU") %>%
# select(final_id, year, entry_year, field, domain, cohort_index,
#        treat, au_random_treatment, starts_with("C_"),
#        publications, citations, ...) %>%   # <- fill in & uncomment
collect()
# Extract MTMT id from final_id, e.g. "mtmt_12345" -> "12345"
df <- df %>% mutate(author_national_base_id := str_extract(final_id, "(?<=^mtmt_)[0-9]+"))
# Left join (keep all panel rows). merge(all.x=TRUE) is an explicit, fast
# data.table left join.
df <- merge(df,
df_cris_pol_index,
by = "author_national_base_id",
all.x = TRUE)
}
gc()
